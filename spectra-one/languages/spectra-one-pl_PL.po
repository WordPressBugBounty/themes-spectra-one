msgid "Updates the FSE global styles color palette and element styles (text, headings, links, buttons) with brand colors. Accepts 4 hex colors: primary, secondary, heading, body. Derives supporting colors (surface, outline, tertiary) automatically."
msgstr "Aktualizuje globalną paletę kolorów i style elementów FSE (tekst, nagłówki, linki, przyciski) za pomocą kolorów marki. Akceptuje 4 kolory w formacie hex: podstawowy, dodatkowy, nagłówka, treści. Automatycznie wyprowadza kolory wspierające (powierzchnia, kontur, trzeciorzędowy)."

#: inc/abilities/settings/update-color-palette.php:129
#: inc/abilities/settings/update-typography.php:160
msgid "No global styles found. Is an FSE/block theme active?"
msgstr "Nie znaleziono globalnych stylów. Czy aktywny jest motyw FSE/blokowy?"

#: inc/abilities/settings/update-color-palette.php:130
#: inc/abilities/settings/update-typography.php:161
msgid "This ability requires an active block theme with global styles support."
msgstr "Ta funkcja wymaga aktywnego motywu blokowego z obsługą globalnych stylów."

#: inc/abilities/settings/update-color-palette.php:143
msgid "Color palette and element styles updated with brand colors."
msgstr "Paleta kolorów i style elementów zaktualizowane o kolory marki."

#: inc/abilities/settings/update-color-palette.php:160
msgid "Exactly 4 brand colors are required: [primary, secondary, heading, body]."
msgstr "Dokładnie 4 kolory marki są wymagane: [podstawowy, dodatkowy, nagłówek, treść]."

#: inc/abilities/settings/update-color-palette.php:161
msgid "Pass an array of 4 hex color strings like [\"#0B3C5D\", \"#328CC1\", \"#D9B310\", \"#86BBD8\"]."
msgstr "Przekaż tablicę 4 ciągów kolorów szesnastkowych, takich jak [\"#0B3C5D\", \"#328CC1\", \"#D9B310\", \"#86BBD8\"]."

