#: inc/abilities/settings/update-navigation.php:56
msgid "Update Navigation Menu"
msgstr "Zaktualizuj menu nawigacyjne"

#: inc/abilities/settings/update-navigation.php:57
msgid "Updates the site navigation menu with page links. Accepts an array of menu items [{label, url}]. Creates the navigation post if needed and wires the header template part to use it. For FSE block themes — uses wp:navigation-link blocks, not classic menus."
msgstr "Aktualizuje menu nawigacyjne witryny z linkami do stron. Akceptuje tablicę elementów menu [{label, url}]. Tworzy wpis nawigacyjny, jeśli to konieczne, i łączy część szablonu nagłówka, aby go użyć. Dla motywów blokowych FSE — używa bloków wp:navigation-link, a nie klasycznych menu."

#: inc/abilities/settings/update-navigation.php:162
msgid "At least one menu item is required."
msgstr "Wymagana jest co najmniej jedna pozycja menu."

#: inc/abilities/settings/update-navigation.php:163
msgid "Provide items as [{\"label\": \"Home\", \"url\": \"/\"}]."
msgstr "Podaj elementy jako [{\"label\": \"Home\", \"url\": \"/\"}]."

#: inc/abilities/settings/update-navigation.php:174
msgid "No valid menu items provided."
msgstr "Nie podano prawidłowych pozycji menu."

#: inc/abilities/settings/update-navigation.php:175
