#: inc/abilities/settings/get-color-palette.php:27
msgid "Get Spectra One Color Palette"
msgstr "Pobierz paletę kolorów Spectra One"

#: inc/abilities/settings/get-color-palette.php:28
msgid "Returns the active Spectra One color palette including any user customizations. Shows all theme colors: primary, secondary, heading, body, background, tertiary, quaternary, surface, foreground, outline, and neutral."
msgstr "Zwraca aktywną paletę kolorów Spectra One, w tym wszelkie dostosowania użytkownika. Pokazuje wszystkie kolory motywu: podstawowy, dodatkowy, nagłówka, treści, tła, trzeci, czwarty, powierzchni, pierwszoplanowy, konturu i neutralny."

#. translators: %d: number of colors
#: inc/abilities/settings/get-color-palette.php:114
#, php-format
msgid "Retrieved color palette with %d colors."
