#: inc/abilities/display/update-post-display-settings.php:27
msgid "Update Post Display Settings"
msgstr "Zaktualizuj ustawienia wyświetlania postów"

#: inc/abilities/display/update-post-display-settings.php:28
msgid "Updates Spectra One display settings for a specific post or page. Toggle header/footer visibility, sticky header, transparent header, or page title display. Only provided fields are updated. Always confirm with the user before running this — state the post title, ID, and which fields will change. Use spectra-one/get-post-display-settings first to show current values."
msgstr "Aktualizuje ustawienia wyświetlania Spectra One dla konkretnego wpisu lub strony. Przełącz widoczność nagłówka/stopki, nagłówek przyklejony, przezroczysty nagłówek lub wyświetlanie tytułu strony. Aktualizowane są tylko podane pola. Zawsze potwierdzaj z użytkownikiem przed uruchomieniem tego — podaj tytuł wpisu, ID i które pola zostaną zmienione. Najpierw użyj spectra-one/get-post-display-settings, aby pokazać bieżące wartości."

#: inc/abilities/display/update-post-display-settings.php:157
msgid "You do not have permission to edit this post."
msgstr "Nie masz uprawnień do edytowania tego posta."

#: inc/abilities/display/update-post-display-settings.php:187
msgid "No display settings provided to update."
msgstr "Nie podano ustawień wyświetlania do zaktualizowania."

#: inc/abilities/display/update-post-display-settings.php:188
msgid "Provide at least one of: hide_header, hide_footer, hide_title, sticky_header, transparent_header."
msgstr "Podaj co najmniej jedno z: hide_header, hide_footer, hide_title, sticky_header, transparent_header."

#. translators: 1: post title, 2: updated fields
#: inc/abilities/display/update-post-display-settings.php:194
#, php-format
msgid "Updated display settings for \"%1$s\": %2$s."
msgstr "Zaktualizowano ustawienia wyświetlania dla \"%1$s\": %2$s."

