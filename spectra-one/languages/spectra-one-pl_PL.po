#: inc/abilities/settings/update-color-palette.php:171
msgid "Colors must be 6-digit hex values like #FF6B6B."
msgstr "Kolory muszą być 6-cyfrowymi wartościami szesnastkowymi, takimi jak #FF6B6B."

