#: inc/abilities/settings/update-theme-settings.php:28
msgid "Updates Spectra One global theme options such as scroll-to-top toggle. Only the provided fields are updated. This modifies options visible to all site visitors. Always confirm with the user before running this — show which settings will change and their new values."
msgstr "Aktualizuje globalne opcje motywu Spectra One, takie jak przełącznik przewijania do góry. Aktualizowane są tylko podane pola. To modyfikuje opcje widoczne dla wszystkich odwiedzających witrynę. Zawsze potwierdzaj z użytkownikiem przed uruchomieniem tego — pokaż, które ustawienia się zmienią i jakie będą ich nowe wartości."

#: inc/abilities/settings/update-theme-settings.php:116
msgid "No settings provided to update."
msgstr "Nie podano ustawień do zaktualizowania."

#: inc/abilities/settings/update-theme-settings.php:117
msgid "Provide at least one setting to update (e.g. scroll_top)."
msgstr "Podaj co najmniej jedno ustawienie do zaktualizowania (np. scroll_top)."

#. translators: %s: list of updated fields
#: inc/abilities/settings/update-theme-settings.php:125
#, php-format
msgid "Theme settings updated: %s."
msgstr "Ustawienia motywu zaktualizowane: %s."

#: inc/abilities/settings/update-typography.php:61
msgid "Update Spectra One Typography"
msgstr "Zaktualizuj typografię Spectra One"

#: inc/abilities/settings/update-typography.php:62
msgid "Updates the FSE global styles typography for body text and headings. Set font family (by slug), font weight, and line height. Font families must be registered in theme.json. Available weights: thin, extraLight, light, regular, medium, semiBold, bold, extraBold, black (or numeric 100-900). Available line heights: initial, xxSmall, xSmall, small, medium, large."
msgstr "Aktualizuje typografię globalnych stylów FSE dla tekstu głównego i nagłówków. Ustaw rodzinę czcionek (według slug), grubość czcionki i wysokość linii. Rodziny czcionek muszą być zarejestrowane w theme.json. Dostępne grubości: cienka, ekstraLekka, lekka, regularna, średnia, półGruba, gruba, ekstraGruba, czarna (lub numerycznie 100-900). Dostępne wysokości linii: początkowa, xxMała, xMała, mała, średnia, duża."

#: inc/abilities/settings/update-typography.php:168
msgid "No typography fields provided to update."
msgstr "Nie podano pól typograficznych do aktualizacji."

#: inc/abilities/settings/update-typography.php:169
msgid "Provide at least one of: body_font_family, body_font_weight, body_line_height, body_font_size, heading_font_family, heading_font_weight, heading_line_height."
msgstr "Podaj co najmniej jedno z: body_font_family, body_font_weight, body_line_height, body_font_size, heading_font_family, heading_font_weight, heading_line_height."

#. translators: %s: comma-separated list of field=value pairs that were rejected
#: inc/abilities/settings/update-typography.php:190
#, php-format
msgid "Invalid typography values: %s."
msgstr "Nieprawidłowe wartości typografii: %s."

#: inc/abilities/settings/update-typography.php:191
msgid "Font weights must be named (thin..black) or numeric (100-900 in steps of 100). Line heights must be named (initial, xxSmall..large) or numeric (0 < n <= 5)."
msgstr "Wagi czcionek muszą być nazwane (thin..black) lub numeryczne (100-900 w krokach co 100). Wysokości linii muszą być nazwane (initial, xxSmall..large) lub numeryczne (0 < n <= 5)."

#. translators: %s: comma-separated list of updated fields
#: inc/abilities/settings/update-typography.php:214
#, php-format
msgid "Typography updated: %s."
msgstr "Typografia zaktualizowana: %s."

#: inc/abilities/theme/get-theme-info.php:27
msgid "Get Spectra One Theme Info"
msgstr "Uzyskaj informacje o motywie Spectra One"

#: inc/abilities/theme/get-theme-info.php:28
msgid "Returns Spectra One theme metadata including version, required WordPress/PHP versions, and Spectra plugin compatibility status. Call this first when working with the theme."
msgstr "Zwraca metadane motywu Spectra One, w tym wersję, wymagane wersje WordPress/PHP oraz status kompatybilności z wtyczką Spectra. Wywołaj to najpierw podczas pracy z motywem."

#. translators: %s: theme version
#: inc/abilities/theme/get-theme-info.php:130
#, php-format
msgid "Spectra One theme v%s info retrieved."
msgstr "Informacje o motywie Spectra One v%s zostały pobrane."

#: inc/abilities/theme/list-hooks.php:27
msgid "List Spectra One Hooks"
msgstr "Lista haków Spectra One"

#: inc/abilities/theme/list-hooks.php:28
msgid "Returns custom action hooks and filters provided by the Spectra One theme via do_action and apply_filters. These are extension points that developers and child themes can hook into. Each hook includes its name, type, accepted parameters, default value, file location, and description."
msgstr "Zwraca niestandardowe haki akcji i filtry dostarczane przez motyw Spectra One za pomocą do_action i apply_filters. Są to punkty rozszerzeń, do których mogą się podłączyć deweloperzy i motywy potomne. Każdy hak zawiera swoją nazwę, typ, akceptowane parametry, domyślną wartość, lokalizację pliku i opis."

#. translators: %d: number of hooks
#: inc/abilities/theme/list-hooks.php:116
#, php-format
msgid "Found %d Spectra One hooks."
msgstr "Znaleziono %d haki Spectra One."

#: inc/abilities/theme/list-hooks.php:139
msgid "Filters the dynamic inline CSS added to the frontend. Extensions append CSS for sticky header, scroll-to-top, navigation, responsive blocks, etc."
msgstr "Filtruje dynamiczny CSS inline dodany do frontendu. Rozszerzenia dodają CSS dla przyklejonego nagłówka, przewijania do góry, nawigacji, responsywnych bloków itp."

#: inc/abilities/theme/list-hooks.php:147
msgid "Filters the dynamic inline JavaScript added to the frontend. Extensions append JS for sticky header, scroll-to-top, admin bar spacing, etc."
msgstr "Filtruje dynamiczny kod JavaScript dodawany do frontendu. Rozszerzenia dodają JS dla przyklejonego nagłówka, przewijania do góry, odstępów paska administracyjnego itp."

#: inc/abilities/theme/list-hooks.php:155
msgid "Controls whether frontend scripts and styles are enqueued. Return false to completely disable theme frontend assets."
msgstr "Kontroluje, czy skrypty i style frontendowe są wczytywane. Zwróć false, aby całkowicie wyłączyć zasoby frontendowe motywu."

#: inc/abilities/theme/list-hooks.php:163
msgid "Controls whether block editor scripts and styles are enqueued. Return false to disable theme editor assets."
msgstr "Kontroluje, czy skrypty i style edytora bloków są wczytywane. Zwróć false, aby wyłączyć zasoby edytora motywów."

#: inc/abilities/theme/list-hooks.php:171
msgid "Filters the localized data array passed to the block editor script. Contains screen ID, Spectra plugin status, and other editor context."
msgstr "Filtruje zlokalizowaną tablicę danych przekazywaną do skryptu edytora bloków. Zawiera identyfikator ekranu, status wtyczki Spectra i inne konteksty edytora."

#: inc/abilities/theme/list-hooks.php:179
msgid "Filters the path to the theme languages directory for loading translations."
msgstr "Filtruje ścieżkę do katalogu języków motywu w celu ładowania tłumaczeń."

#: inc/abilities/theme/list-hooks.php:187
msgid "Filters the SVG icons array used by the theme. Add, remove, or modify available SVG icons."
msgstr "Filtruje tablicę ikon SVG używanych przez motyw. Dodaj, usuń lub zmodyfikuj dostępne ikony SVG."

#: inc/abilities/theme/list-hooks.php:195
msgid "Controls whether the mobile modal navigation menu content is centered. Return false to disable centering."
msgstr "Określa, czy treść mobilnego modalnego menu nawigacyjnego jest wyśrodkowana. Zwróć false, aby wyłączyć wyśrodkowanie."

#: inc/abilities/theme/list-hooks.php:203
msgid "Filters the default block spacing value (in pixels) used in the Spectra plugin editor."
msgstr "Filtruje domyślną wartość odstępu bloków (w pikselach) używaną w edytorze wtyczki Spectra."

#: inc/abilities/theme/list-hooks.php:211
msgid "Controls whether a specific Spectra One ability is visible in the REST API. Receives the ability ID and instance as additional parameters."
msgstr "Kontroluje, czy konkretna umiejętność Spectra One jest widoczna w REST API. Otrzymuje ID umiejętności i instancję jako dodatkowe parametry."

#: inc/abilities/theme/list-hooks.php:219
msgid "Controls whether a specific Spectra One ability is publicly exposed via MCP (Model Context Protocol). Receives the ability ID and instance as additional parameters."
msgstr "Kontroluje, czy konkretna zdolność Spectra One jest publicznie udostępniona za pośrednictwem MCP (Model Context Protocol). Otrzymuje identyfikator zdolności i instancję jako dodatkowe parametry."

#: inc/abilities/theme/list-style-variations.php:27
msgid "List Spectra One Style Variations"
msgstr "Wylistuj wariacje stylu Spectra One"

#: inc/abilities/theme/list-style-variations.php:28
msgid "Returns all available Spectra One style variations (color schemes) with their titles and color palettes. Use this to see what visual themes are available."
msgstr "Zwraca wszystkie dostępne warianty stylu Spectra One (schematy kolorów) wraz z ich tytułami i paletami kolorów. Użyj tego, aby zobaczyć, jakie motywy wizualne są dostępne."

#. translators: %d: number of variations
#: inc/abilities/theme/list-style-variations.php:127
#, php-format
msgid "Found %d style variations."
msgstr "Znaleziono %d wariantów stylu."

