msgid "Pass an array of 4 hex color strings like [\"#0B3C5D\", \"#328CC1\", \"#D9B310\", \"#86BBD8\"]."
msgstr "Pasa un arreglo de 4 cadenas de colores hexadecimales como [\"#0B3C5D\", \"#328CC1\", \"#D9B310\", \"#86BBD8\"]."

